/dts-v1/;
/plugin/;

#include <dt-bindings/board/am335x-bbw-bbb-base.h>
#include <dt-bindings/pinctrl/am33xx.h>

/ {
    compatible = "ti,beaglebone", "ti,beaglebone-black";
    part-number = "BB-DCAN1";
    version = "00A0";

    exclusive-use = "P9.24", "P9.26", "dcan1";

    /* Override DCAN1 pinctrl with a zero-pin stub so the driver probes
       without claiming P9.24/P9.26 from the cape manager.
       setup_can.sh sets pin states via sysfs after can1 up. */
    fragment@0 {
        target = <&am33xx_pinmux>;
        __overlay__ {
            bb_dcan1_stub: pinmux_bb_dcan1_stub {
                /* no pins — prevents the driver from claiming any mux pins */
            };
        };
    };

    fragment@1 {
        target = <&dcan1>;
        __overlay__ {
            status = "okay";
            pinctrl-names = "default";
            pinctrl-0 = <&bb_dcan1_stub>;
        };
    };
};
